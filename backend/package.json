{
  "name": "liens-vivants-backend",
  "version": "1.0.0",
  "description": "Express REST API for Liens Vivants",
  "license": "GPL-3.0-only",
  "main": "dist/server.js",
  "scripts": {
    "start": "node --experimental-sqlite dist/server.js",
    "build": "tsc",
    "dev": "NODE_OPTIONS='--experimental-sqlite' tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.17",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
