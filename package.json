{
  "name": "liens-vivants",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --dir backend dev\" \"pnpm --dir frontend dev\"",
    "build": "pnpm --dir frontend build",
    "start": "pnpm --dir backend start",
    "lint": "oxlint backend/src frontend/src",
    "format": "oxfmt backend/src frontend/src",
    "format:check": "oxfmt --check backend/src frontend/src",
    "typecheck": "pnpm --dir backend typecheck && pnpm --dir frontend typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
